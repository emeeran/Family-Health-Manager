# Health Manager Configuration
# Edit this file to customize your installation.

# Application environment
# "development" allows SQLite. "production" requires PostgreSQL.
APP_ENV=development

# Secret key for JWT signing — auto-generated on first install
SECRET_KEY=<generate-on-install>

# Database URL
# SQLite (default — stores in /var/lib/health-manager/data/):
DATABASE_URL=sqlite+aiosqlite:////var/lib/health-manager/data/health.db
# PostgreSQL (required for APP_ENV=production):
# DATABASE_URL=postgresql+asyncpg://healthmgr:password@localhost:5432/healthmanager

# File storage path (attachments, backups)
STORAGE_PATH=/var/lib/health-manager/data/attachments

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8080

# External port for Caddy to listen on
PORT=8080

# Redis URL (leave empty for in-memory fallback)
REDIS_URL=

# Health check secret (leave empty for development auto-derived value)
HEALTH_CHECK_SECRET=

# Run background scheduler (reminders, backups, etc.)
RUN_SCHEDULER=true

# AI provider (optional — leave empty to disable AI features)
OLLAMA_LOCAL_URL=http://localhost:11434
OLLAMA_MODEL=medgemma
OLLAMA_TEXT_MODEL=gemma3:4b
