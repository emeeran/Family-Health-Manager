#!/bin/bash
set -e

# Pre-remove script for health-manager

case "$1" in
    remove|upgrade|deconfigure)
        # Stop services before removal
        systemctl stop health-manager-caddy.service 2>/dev/null || true
        systemctl stop health-manager.service 2>/dev/null || true
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        ;;
esac

exit 0
